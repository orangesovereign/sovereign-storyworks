      "onFailure": "pay"
    },
    "pay": {
      "type": "reward",
      "config": { "money": 12.0 },
      "onSuccess": "done"
    },
    "done": {
      "type": "end",
      "config": { "outcome": "completed", "message": "The county thanks its lawmen." }
    }
  }
}
